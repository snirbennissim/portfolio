{
  "headers": [
    {
      "source": "/resume.pdf",
      "headers": [
        { "key": "Content-Type", "value": "application/pdf" },
        { "key": "Content-Disposition", "value": "attachment; filename=\"Snir_Ben_Nissim_Resume.pdf\"" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!.*\\.).*)","destination": "/index.html" }
  ]
}
